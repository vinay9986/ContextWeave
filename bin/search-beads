#!/usr/bin/env node
'use strict';

/**
 * search-beads — semantic search over the ContextWeave bead store.
 *
 * Usage:
 *   search-beads "<natural language query>"
 *
 * Examples:
 *   search-beads "2nd email about dogs"
 *   search-beads "poem about the ocean"
 *   search-beads "how to configure webpack"
 *
 * Works as a native Bash tool for both Claude Code and Gemini CLI —
 * no MCP or extra configuration needed beyond `npm link` + `node setup-onnx.js`.
 *
 * How it works:
 *   1. Loads all prompt beads from the .beads store (via `bd list`).
 *   2. Resolves each prompt's final-response child.
 *   3. Stage 1a: exact ordinal lookup — (format, entity) key match.
 *   3. Stage 1b: format-only ordinal lookup.
 *   3. Stage 1c: semantic ordinal — embeds the format+entity description,
 *      finds the most similar prompts, applies ordinal within that group.
 *   4. Stage 2: full semantic search — cosine similarity over all bead content.
 *   5. Prints the matched bead content (prompt snippet + assistant response).
 */

const { execFileSync } = require('child_process');
const path = require('path');
const os = require('os');

// ── Constants ──────────────────────────────────────────────────────────────────

const MODEL = 'Xenova/all-MiniLM-L6-v2';
const CACHE_DIR = path.join(os.homedir(), '.cache', 'contextweave-onnx');

const FORMATS = [
  'short news article', 'short scene in a play', 'short essay',
  'social media post', 'formal letter', 'diary entry',
  'blog post', 'short story', 'cover letter', 'product description',
  'press release', 'marketing email', 'news article',
  'speech', 'poem', 'haiku', 'sonnet', 'limerick', 'song', 'rap',
  'essay', 'letter', 'email', 'riddle', 'joke', 'story',
];

const FORMAT_PATTERN = new RegExp(
  '\\b(' + FORMATS.slice().sort((a, b) => b.length - a.length).map(escapeRegex).join('|') + ')\\b',
  'i'
);

const ORDINAL_PATTERN = /(?:prepend\s+\S+\s+to\s+the\s+)?(\d+)(?:st|nd|rd|th)\s+\(1\s+indexed\)\s+(.+?)\s+about\s+(.+?)(?:\.|$)/i;
const USER_PATTERN = /write\s+(?:a\s+|an\s+)?(?:short\s+)?(.+?)\s+about\s+(.+?)(?:\.|$)/i;

function escapeRegex(str) {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// ── ONNX embedder ──────────────────────────────────────────────────────────────

let _extractor = null;

async function getExtractor() {
  if (_extractor) return _extractor;
  const { pipeline, env } = await import('@huggingface/transformers');
  env.cacheDir = CACHE_DIR;
  _extractor = await pipeline('feature-extraction', MODEL);
  return _extractor;
}

function dotProduct(a, b) {
  let s = 0;
  for (let i = 0; i < a.length; i++) s += a[i] * b[i];
  return s;
}

// ── bd helpers ─────────────────────────────────────────────────────────────────

function runBd(args, cwd) {
  try {
    const env = process.env.BEADS_DIR
      ? { ...process.env }
      : { ...process.env, BEADS_DIR: path.join(cwd, '.beads') };
    return execFileSync('bd', [...args, '--json', '--quiet'], { cwd, env, encoding: 'utf8' }).trim();
  } catch (_) {
    return '';
  }
}

function bdJson(args, cwd) {
  const out = runBd(args, cwd);
  if (!out) return null;
  try { return JSON.parse(out); } catch (_) { return null; }
}

function asIssueList(data) {
  if (Array.isArray(data)) return data.filter(Boolean);
  if (data && Array.isArray(data.issues)) return data.issues.filter(Boolean);
  return [];
}

function parseNotes(notes) {
  if (!notes) return {};
  try { return JSON.parse(notes); } catch (_) { return {}; }
}

// ── Bead loading ───────────────────────────────────────────────────────────────

function loadBeads(cwd) {
  const prompts = asIssueList(
    bdJson(['list', '--all', '--label', 'trace', '--label', 'prompt', '--limit', '0', '--sort', 'created', '--reverse'], cwd)
  );

  prompts.sort((a, b) => {
    const aT = a.created_at ? Date.parse(a.created_at) : 0;
    const bT = b.created_at ? Date.parse(b.created_at) : 0;
    return aT - bT;
  });

  return prompts.map((prompt, idx) => {
    const pNotes = parseNotes(prompt.notes);
    const promptSnippet = pNotes.snippet || prompt.title || '';

    const children = asIssueList(
      bdJson(['list', '--all', '--parent', prompt.id, '--sort', 'created', '--reverse', '--limit', '0'], cwd)
    );
    const finalChild = children.find((c) => (c.labels || []).includes('final'));
    const fNotes = parseNotes(finalChild && finalChild.notes);
    const finalSnippet = fNotes.snippet || '';

    const fmt = extractFormat(promptSnippet);
    const entity = extractEntity(promptSnippet);

    return {
      id: prompt.id,
      turn: idx + 1,
      promptSnippet,
      finalSnippet,
      entity,
      formatType: fmt,
    };
  });
}

// ── Metadata extraction ────────────────────────────────────────────────────────

function extractFormat(text) {
  const m = FORMAT_PATTERN.exec(text);
  return m ? m[1].toLowerCase() : '';
}

function extractEntity(text) {
  const m = USER_PATTERN.exec(text);
  if (m) return m[2].trim().replace(/[?.!]+$/, '');
  const m2 = /\babout\s+(.+?)(?:\.|$)/i.exec(text);
  return m2 ? m2[1].trim().replace(/[?.!]+$/, '') : '';
}

// ── Query parsing ──────────────────────────────────────────────────────────────

function parseOrdinalQuery(query) {
  const m = ORDINAL_PATTERN.exec(query);
  if (!m) return null;
  return {
    ordinal: parseInt(m[1], 10),
    formatType: m[2].trim().toLowerCase(),
    entity: m[3].trim().replace(/[?.!]+$/, ''),
  };
}

// ── Search ─────────────────────────────────────────────────────────────────────

async function search(beads, query) {
  const parsed = parseOrdinalQuery(query);

  // Stage 1a: exact (format, entity) match
  if (parsed) {
    const exactGroup = beads.filter(
      (b) => b.formatType === parsed.formatType &&
             b.entity.toLowerCase() === parsed.entity.toLowerCase()
    );
    if (exactGroup.length && parsed.ordinal >= 1 && parsed.ordinal <= exactGroup.length) {
      return exactGroup[parsed.ordinal - 1];
    }

    // Stage 1b: format-only match
    const formatGroup = beads.filter((b) => b.formatType === parsed.formatType);
    if (formatGroup.length && parsed.ordinal >= 1 && parsed.ordinal <= formatGroup.length) {
      return formatGroup[parsed.ordinal - 1];
    }
  }

  // Stages 1c and 2 both require the embedder
  const extractor = await getExtractor();

  // Stage 1c: semantic ordinal group matching
  if (parsed) {
    const groupQuery = `${parsed.formatType} about ${parsed.entity}`;
    const promptTexts = beads.map((b) => b.promptSnippet);
    const [promptEmbeds, groupEmbed] = await Promise.all([
      extractor(promptTexts, { pooling: 'mean', normalize: true }),
      extractor([groupQuery], { pooling: 'mean', normalize: true }),
    ]);

    const dim = groupEmbed.dims[1];
    const qVec = Array.from(groupEmbed.data);
    const nCandidates = Math.min(parsed.ordinal * 2 + 2, beads.length);

    const scored = beads
      .map((b, i) => ({
        bead: b,
        score: dotProduct(qVec, Array.from(promptEmbeds.data).slice(i * dim, (i + 1) * dim)),
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, nCandidates)
      .sort((a, b) => beads.indexOf(a.bead) - beads.indexOf(b.bead)); // restore turn order

    if (parsed.ordinal >= 1 && parsed.ordinal <= scored.length) {
      return scored[parsed.ordinal - 1].bead;
    }
  }

  // Stage 2: full semantic search
  const texts = beads.map((b) => b.promptSnippet + ' ' + b.finalSnippet);
  const [corpusEmbeds, queryEmbed] = await Promise.all([
    extractor(texts, { pooling: 'mean', normalize: true }),
    extractor([query], { pooling: 'mean', normalize: true }),
  ]);

  const dim = queryEmbed.dims[1];
  const qVec = Array.from(queryEmbed.data);

  let best = null;
  let bestScore = -Infinity;
  for (let i = 0; i < beads.length; i++) {
    const score = dotProduct(qVec, Array.from(corpusEmbeds.data).slice(i * dim, (i + 1) * dim));
    if (score > bestScore) { bestScore = score; best = beads[i]; }
  }

  return best;
}

// ── Formatting ─────────────────────────────────────────────────────────────────

function formatResult(bead) {
  return [
    `[bead-${String(bead.turn).padStart(4, '0')}] Turn #${bead.turn}`,
    '',
    `User: ${bead.promptSnippet}`,
    '',
    `Assistant: ${bead.finalSnippet || '(no response recorded)'}`,
  ].join('\n');
}

// ── Main ───────────────────────────────────────────────────────────────────────

async function main() {
  const query = process.argv.slice(2).join(' ').trim();

  if (!query) {
    process.stderr.write('Usage: search-beads "<query>"\n');
    process.exit(1);
  }

  const cwd = process.env.SEARCH_BEADS_CWD || process.cwd();

  const fs = require('fs');
  const beadsDir = process.env.BEADS_DIR || path.join(cwd, '.beads');
  if (!fs.existsSync(beadsDir)) {
    process.stderr.write(`No beads store found. Tried: ${beadsDir}\n`);
    process.stderr.write('Set BEADS_DIR or run `bd init` in the project root.\n');
    process.exit(1);
  }

  const beads = loadBeads(cwd);
  if (!beads.length) {
    process.stdout.write('No beads found in the store.\n');
    process.exit(0);
  }

  const result = await search(beads, query);

  if (!result) {
    process.stdout.write('No matching beads found.\n');
    process.exit(0);
  }

  process.stdout.write(formatResult(result) + '\n');
}

main().catch(err => {
  process.stderr.write(`search-beads error: ${err.message}\n`);
  process.exit(1);
});
